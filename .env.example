# Public Supabase client config — Vite bundles these into the browser build, so they are
# SAFE TO EXPOSE (the publishable key is the anon key, protected by Row Level Security).
# Copy to .env.local for local dev. Real secrets (service-role keys, API tokens) belong in
# .env.local (gitignored) or the Supabase/Netlify dashboards — NEVER commit them.
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
